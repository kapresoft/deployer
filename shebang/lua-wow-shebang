#!/usr/bin/env lua
--[[-----------------------------------------------------------------------------
Usage:
-- place on top of the script
#!/usr/bin/env lua-wow-shebang
-------------------------------------------------------------------------------]]

local s = '[lua-wow-shebang]:: '
local verbose = false
local function p(...) print(s, ...) end
if verbose then p('verbose=', verbose) end

local function shell_exec(cmd)
    local f = io.popen(cmd .. " 2>/dev/null")
    if not f then return nil end
    local result = f:read("*a"):gsub("^%s+", ""):gsub("%s+$", "")
    local success = f:close()
    if success and result ~= "" then return result end
    return nil
end

local function resolve(path)
    local safe = path:gsub("'", "'\\''")

    -- macOS: readlink -f works on recent versions
    -- Linux: readlink -f is standard (GNU coreutils)
    local result = shell_exec("readlink -f '" .. safe .. "'")
    if result then return result end

    -- macOS fallback: realpath available on some versions
    -- Linux fallback: realpath from GNU coreutils
    result = shell_exec("realpath '" .. safe .. "'")
    if result then return result end

    -- Python fallback: available on macOS and most Linux distros
    result = shell_exec("python3 -c 'import os; print(os.path.realpath(\"" .. safe .. "\"))'")
    if result then return result end

    -- Perl fallback: universally available
    result = shell_exec("perl -MCwd=realpath -e 'print realpath(shift)' '" .. safe .. "'")
    if result then return result end

    -- Last resort: return original path
    return path
end

--- @return string
local function getInstallDir()
  -- Resolve the install_dir: {install_dir}/shebang/lua-wow-shebang
  local wrapper_source = debug.getinfo(1, "S").source:match("^@(.*)")
  local real_wrapper = resolve(wrapper_source)
  local install_dir = real_wrapper:match("(.*)/"):match("(.*)/")
  if verbose then
    p(s, 'wrapper_source=', wrapper_source)
    p(s, 'real_wrapper=', real_wrapper)
    p(s, 'install_dir=', install_dir)
  end
  return install_dir
end

local install_dir = getInstallDir()
if not install_dir then return end

-- Set up module paths
local paths = {
    install_dir .. "/lua/lib/?.lua",
    install_dir .. "/lua/?.lua",
    install_dir .. "/lua/?/init.lua",
    package.path,
}

package.path = table.concat(paths, ";")

if verbose then
  p(s, 'package.path=', package.path)
end

local script = arg[1]
if not script then
  p("Usage: lua-wow-shebang <script> [args...]")
  os.exit(1)
end

-- Resolve the script path
local real_script = resolve(script)
table.remove(arg, 1) -- Remove script name from args

-- Execute the script
dofile(real_script)
